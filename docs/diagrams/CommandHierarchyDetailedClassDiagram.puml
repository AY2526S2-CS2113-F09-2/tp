@startuml
!pragma layout smetana
skinparam classAttributeIconSize 0
left to right direction

title Command Hierarchy Class Diagram

abstract class Command {
  +execute(list: RecordList): void
  +isExit(): boolean
}

class Parser {
  {static} +parse(userInput: String, ui: Ui): Command
}

class Ui {
  +showMessage(message: String): void
  +showError(message: String): void
  +readCommand(): String
}

class RecordList {
  +add(record: Record): void
  +getRecord(index: int): Record
  +removeIndex(index: int): void
}

class Record {
  +addBullet(text: String): void
  +editBullet(index: int, text: String): void
  +moveBullet(fromIndex: int, toIndex: int): void
  +deleteBullet(index: int): String
}

class User {
  +getInstance(): User
  +editField(field: String, value: String): void
}

class ResumakeException {
  +ResumakeException(message: String)
}

class AddCommand {
  -r: Record
  -ui: Ui
  +execute(list: RecordList): void
}
class AddBulletCommand {
  -index: int
  -bullet: String
  -ui: Ui
  +execute(list: RecordList): void
}
class DeleteCommand {
  -userRecordIndex: int
  -userBulletIndex: int
  -isDeleteBulletMode: boolean
  -ui: Ui
  +execute(list: RecordList): void
}
class EditCommand {
  -index: int
  -newTitle: String
  -newRole: String
  -newTech: String
  +execute(list: RecordList): void
}
class EditBulletCommand {
  -userRecordIndex: int
  -userBulletIndex: int
  -newBullet: String
  -ui: Ui
  +execute(list: RecordList): void
}
class EditUserCommand {
  -field: String
  -ui: Ui
  +execute(list: RecordList): void
}
class ExitCommand {
  -ui: Ui
  +execute(list: RecordList): void
  +isExit(): boolean
}
class FindCommand {
  -keyword: String
  -ui: Ui
  +execute(list: RecordList): void
}
class FindBulletCommand {
  -keyword: String
  -ui: Ui
  +execute(list: RecordList): void
}
class GenerateCommand {
  -ui: Ui
  +execute(list: RecordList): void
}
class HelpCommand {
  -ui: Ui
  +execute(list: RecordList): void
}
class ListCommand {
  -type: String
  -ui: Ui
  +execute(list: RecordList): void
}
class MoveBulletCommand {
  -recordIndex: int
  -fromBulletIndex: int
  -toBulletIndex: int
  -ui: Ui
  +execute(list: RecordList): void
}
class ShowCommand {
  -index: int
  -ui: Ui
  +execute(list: RecordList): void
}
class SortCommand {
  -ui: Ui
  +execute(list: RecordList): void
}

Command <|-- AddCommand
Command <|-- AddBulletCommand
Command <|-- DeleteCommand
Command <|-- EditCommand
Command <|-- EditBulletCommand
Command <|-- EditUserCommand
Command <|-- ExitCommand
Command <|-- FindCommand
Command <|-- FindBulletCommand
Command <|-- GenerateCommand
Command <|-- HelpCommand
Command <|-- ListCommand
Command <|-- MoveBulletCommand
Command <|-- ShowCommand
Command <|-- SortCommand

Parser ..> Command : dispatches
AddCommand ..> RecordList
AddCommand ..> Ui
AddBulletCommand ..> Record
AddBulletCommand ..> RecordList
AddBulletCommand ..> Ui
DeleteCommand ..> RecordList
DeleteCommand ..> Record
DeleteCommand ..> Ui
DeleteCommand ..> ResumakeException
EditCommand ..> Record
EditCommand ..> RecordList
EditCommand ..> Ui
EditBulletCommand ..> Record
EditBulletCommand ..> RecordList
EditBulletCommand ..> Ui
EditBulletCommand ..> ResumakeException
EditUserCommand ..> User
EditUserCommand ..> Ui
EditUserCommand ..> ResumakeException
ExitCommand ..> Ui
FindCommand ..> RecordList
FindCommand ..> Record
FindCommand ..> Ui
FindBulletCommand ..> RecordList
FindBulletCommand ..> Record
FindBulletCommand ..> Ui
MoveBulletCommand ..> Record
MoveBulletCommand ..> RecordList
MoveBulletCommand ..> Ui
ShowCommand ..> RecordList
ShowCommand ..> Record
ShowCommand ..> Ui
SortCommand ..> RecordList
SortCommand ..> Ui
GenerateCommand ..> RecordList
GenerateCommand ..> User
GenerateCommand ..> Ui
HelpCommand ..> Ui

@enduml
