@startuml
!pragma layout smetana
skinparam classAttributeIconSize 0
left to right direction

title Delete and Storage Class Diagram

class DeleteCommand {
  -userRecordIndex: int
  -userBulletIndex: int
  -isDeleteBulletMode: boolean
  +DeleteCommand(userRecordIndex: int)
  +DeleteCommand(userRecordIndex: int, userBulletIndex: int)
  +execute(list: RecordList): void
}

class Parser {
  {static} +parse(userInput: String, ui: Ui): Command
}

class Storage {
  -filepath: String
  +saveToFile(list: RecordList): void
  +loadFromFile(filepath: String): RecordList
  -parseRecord(line: String): Record
  -getKeyword(recordType: String): String
}

class RecordList {
  +getRecord(index: int): Record
  +removeIndex(index: int): void
}

Parser ..> DeleteCommand : creates
DeleteCommand ..> RecordList : mutates
Storage ..> RecordList : save/load

@enduml
