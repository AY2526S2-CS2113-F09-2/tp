@startuml
!pragma layout smetana
skinparam classAttributeIconSize 0

title Full System Class Diagram

package "seedu.duke" {
  class Resumake {
    +run(): void
    +main(args: String[]): void
  }

  class Ui {
    +showLine(): void
    +showMessage(message: String): void
    +showPrompt(): void
    +showError(message: String): void
    +showLoadingError(): void
    +readCommand(): String
    +greetings(): void
  }

  class Parser {
    {static} +parse(userInput: String): Command
    {static} +parse(userInput: String, ui: Ui): Command
  }

  class ParsedFields {
    +title: String
    +role: String
    +tech: String
    +from: YearMonth
    +to: YearMonth
  }

  class RecordList {
    -size: int
    +add(record: Record): void
    +getRecord(index: int): Record
    +removeIndex(index: int): void
    +sort(comparator): void
    +contains(record: Record): boolean
    +getSize(): int
  }

  class Storage {
    -filepath: String
    -ui: Ui
    +saveToFile(list: RecordList): void
    +loadFromFile(filepath: String): RecordList
    {static} +getFilepath(): String
  }

  class User {
    -{static} instance: User
    -name: String
    -number: int
    -email: String
    -skills: HashMap<String, Integer>
    {static} +getInstance(): User
    {static} +loadFrom(name: String, number: int, email: String): void
    +editField(field: String, value: String): void
    +getName(): String
    +getNumber(): Integer
    +getEmail(): String
    +addSkills(skill: String): void
    +removeSkills(skill: String): void
    +getSkillsAsString(): String
  }
}

package "seedu.duke.commands" {
  abstract class Command {
    +execute(list: RecordList): void
    +isExit(): boolean
  }

  class AddCommand {
    -r: Record
    -ui: Ui
    +execute(list: RecordList): void
  }
  class AddBulletCommand {
    -index: int
    -bullet: String
    -ui: Ui
    +execute(list: RecordList): void
  }
  class DeleteCommand {
    -userRecordIndex: int
    -userBulletIndex: int
    -isDeleteBulletMode: boolean
    -ui: Ui
    +execute(list: RecordList): void
  }
  class EditCommand {
    -index: int
    -newTitle: String
    -newRole: String
    -newTech: String
    +execute(list: RecordList): void
  }
  class EditBulletCommand {
    -userRecordIndex: int
    -userBulletIndex: int
    -newBullet: String
    -ui: Ui
    +execute(list: RecordList): void
  }
  class EditUserCommand {
    -field: String
    -ui: Ui
    +execute(list: RecordList): void
  }
  class ExitCommand {
    -ui: Ui
    +execute(list: RecordList): void
    +isExit(): boolean
  }
  class FindCommand {
    -keyword: String
    -ui: Ui
    +execute(list: RecordList): void
  }
  class FindBulletCommand {
    -keyword: String
    -ui: Ui
    +execute(list: RecordList): void
  }
  class GenerateCommand {
    -ui: Ui
    +execute(list: RecordList): void
  }
  class HelpCommand {
    -ui: Ui
    +execute(list: RecordList): void
  }
  class ListCommand {
    -type: String
    -ui: Ui
    +execute(list: RecordList): void
  }
  class MoveBulletCommand {
    -recordIndex: int
    -fromBulletIndex: int
    -toBulletIndex: int
    -ui: Ui
    +execute(list: RecordList): void
  }
  class ShowCommand {
    -index: int
    -ui: Ui
    +execute(list: RecordList): void
  }
  class SortCommand {
    -ui: Ui
    +execute(list: RecordList): void
  }

  Command <|-- AddCommand
  Command <|-- AddBulletCommand
  Command <|-- DeleteCommand
  Command <|-- EditCommand
  Command <|-- EditBulletCommand
  Command <|-- EditUserCommand
  Command <|-- ExitCommand
  Command <|-- FindCommand
  Command <|-- FindBulletCommand
  Command <|-- GenerateCommand
  Command <|-- HelpCommand
  Command <|-- ListCommand
  Command <|-- MoveBulletCommand
  Command <|-- ShowCommand
  Command <|-- SortCommand
}

package "seedu.duke.recordtype" {
  class Record {
    #title: String
    #role: String
    #tech: String
    #from: YearMonth
    #to: YearMonth
    #recordType: String
    #bullets: ArrayList<String>
  }

  class Project {
    +Project(title: String, role: String, tech: String, from: YearMonth, to: YearMonth)
  }
  class Experience {
    +Experience(title: String, role: String, tech: String, from: YearMonth, to: YearMonth)
  }
  class Cca {
    +Cca(title: String, role: String, tech: String, from: YearMonth, to: YearMonth)
  }

  Record <|-- Project
  Record <|-- Experience
  Record <|-- Cca
}

package "seedu.duke.exceptions" {
  class ResumakeException {
    +ResumakeException(message: String)
  }
}

Resumake *-- Ui
Resumake *-- Storage
Resumake *-- RecordList
Resumake ..> Parser
Resumake ..> Command

Parser ..> Command : creates
Parser ..> ParsedFields
Parser ..> Project
Parser ..> Experience
Parser ..> Cca
Parser ..> ResumakeException

RecordList o-- "*" Record
RecordList ..> User : add/remove skills

Storage ..> RecordList : load/save
Storage ..> Record : parse/serialize
Storage ..> User : persist/load
Storage ..> ResumakeException

AddCommand ..> RecordList
AddBulletCommand ..> RecordList
AddBulletCommand ..> Record
DeleteCommand ..> RecordList
DeleteCommand ..> Record
EditCommand ..> RecordList
EditCommand ..> Record
EditBulletCommand ..> RecordList
EditBulletCommand ..> Record
EditUserCommand ..> User
FindCommand ..> RecordList
FindBulletCommand ..> RecordList
GenerateCommand ..> RecordList
GenerateCommand ..> User
HelpCommand ..> Ui
ListCommand ..> RecordList
MoveBulletCommand ..> RecordList
MoveBulletCommand ..> Record
ShowCommand ..> RecordList
SortCommand ..> RecordList

Command ..> ResumakeException
@enduml
